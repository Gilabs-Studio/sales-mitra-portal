PORT=8080
DATABASE_URL=file:data/mitra-sales.db?cache=shared
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h
WEB_ORIGIN=http://localhost:3000,http://localhost:8089,http://127.0.0.1:3000,http://127.0.0.1:8089
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Salesview <onboarding@resend.dev>

# AI product knowledge assistant. API key hanya disimpan di backend.
CEREBRAS_BASE_URL=https://api.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_MAX_COMPLETION_TOKENS=520
CEREBRAS_TIMEOUT=8s

# Bootstrap super admin
ADMIN_NAME=GiLabs Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@gilabs.local
ADMIN_PASSWORD=admin12345

DEMO_PARTNER_NAME=Mitra Demo
DEMO_PARTNER_EMAIL=mitra@gilabs.local
DEMO_PARTNER_PASSWORD=mitra12345
