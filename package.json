{
  "name": "mitra-sales-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "sh -c 'pnpm --dir apps/api dev & pnpm --dir apps/web dev & wait'",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:mobile": "cd apps/mobile && flutter run",
    "build:web": "pnpm --dir apps/web build",
    "analyze:mobile": "cd apps/mobile && flutter analyze",
    "test:mobile": "cd apps/mobile && flutter test",
    "lint:web": "pnpm --dir apps/web lint",
    "dev:api": "pnpm --dir apps/api dev",
    "test:api": "pnpm --dir apps/api test",
    "format:api": "cd apps/api && gofmt -w ./cmd ./internal",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  }
}
